{{ 's-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'j-header.js' | asset_url }}" defer="defer"></script>

<div class="h_">
  <div class="h-ph"></div>

  <header id="h" class="h">
    <!-- Header Left -->
    <div class="h_l">
      {% render 'menu-icon' %}
      <nav class="h_n">
        {% for link in linklists['main-menu'].links -%}
          <div class="h_n-item">
            {{ link.title | link_to: link.url }}

            <!-- Dropdown Menu -->
            {% if link.links.size > 0 %}
              {% render 'dropdown-menu', links: link.links %}
            {% endif %}
          </div>
        {%- endfor %}
      </nav>
    </div>

    <!-- Header Middle -->
    <div class="h_m">
      <a href="/">
        {% if settings.logo %}
          <figure>
            {{ settings.logo | image_url: width: 200 | image_tag }}
          </figure>
        {% else %}
          <span>
            {{ shop.name }}
          </span>
        {% endif %}
      </a>
    </div>

    <!-- Header Right -->
    <div class="h_r">
      <div>Search</div>
      <div>{{ 'Login' | link_to: routes.account_login_url }}</div>
      <button class="h_cb" type="button">
        Shopping bag (<span id="cart-count" class="h_cb_count">{{- cart.item_count -}}</span>)
      </button>
    </div>
  </header>

  <!-- MENU DRAWER -->
  {% render 'menu-drawer' %}
</div>

{% schema %}
{
  "name": "header",
  "settings": []
}
{% endschema %}
