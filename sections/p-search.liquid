<div>
  <h2>Search</h2>
  <form action="{{ routes.search_url }}">
    <input
      type="text"
      placeholder="Search"
      name="q"
      value="{{ search.terms | escape }}"
    >
    <input type="submit" value="Search">
  </form>
  <div class="search_results">
    {% for item in search.results %}
      <div>
        {{ item.title | link_to: item.url }}
        <figure>
          {{ item.featured_image | image_url: width: 500 | image_tag }}
        </figure>
      </div>
    {% endfor %}
  </div>
</div>
{% schema %}
{
  "name": "search",
  "settings": []
}
{% endschema %}
