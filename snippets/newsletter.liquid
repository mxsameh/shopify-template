{{ 's-newsletter.css' | asset_url | stylesheet_tag }}

  {% form 'customer', class: 'nl_form' %}
    <input type="hidden" name="contact[tags]" value="newsletter">
    <fieldset>
      <label for="NewsletterForm--{{ section.id }}">Subscribe to our Newsletter</label>
      <div>
        <input
          id="NewsletterForm--{{ section.id }}"
          type="email"
          name="contact[email]"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          {% if form.errors %}
            autofocus
          {% endif %}
          placeholder="Your email address"
          required
        >
        <button
          type="submit"
        >
          {{ 'i-chev.svg' | inline_asset_content }}
        </button>
      </div>
    </fieldset>

    {%- if form.errors -%}
      <small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">
        {{- form.errors.translated_fields.email | capitalize }}
        {{ form.errors.messages.email -}}
      </small>
    {%- endif -%}
    {%- if form.posted_successfully? -%}
      <h3
        class="newsletter-form__message newsletter-form__message--success form__message"
        id="Newsletter-success--{{ section.id }}"
        tabindex="-1"
        autofocus
      >
        Welcome to the family!
      </h3>
    {%- endif -%}
  {% endform %}

{% javascript %}
  const form = document.querySelector('.nl_form');
  console.log('hee', form);

  form.addEventListener('submit', function (e) {
    e.preventDefault();
  });
{% endjavascript %}
